{
  "version": 1,
  "amountUnit": "thousand_ntd",
  "datasets": [
    {
      "id": "population_annual",
      "title": "歷年總人口",
      "domain": "population",
      "input": "population_annual.csv",
      "output": "population_annual.json",
      "required": true,
      "cadence": "annual",
      "source": "嘉義市戶政服務網",
      "pages": ["/", "/population", "/narratives"],
      "fields": ["year", "total_population", "male", "female", "households", "growth_pct"],
      "notes": "目前未包含出生、死亡、遷入、遷出；自然/社會增減需由戶籍登記分析表補齊。"
    },
    {
      "id": "population_age_gender",
      "title": "年齡性別結構",
      "domain": "population",
      "input": "population_age_gender.csv",
      "output": "population_age_gender.json",
      "required": true,
      "cadence": "snapshot",
      "source": "嘉義市戶政服務網",
      "pages": ["/population"],
      "fields": ["age_group", "male", "female", "total", "age_midpoint"]
    },
    {
      "id": "population_village_monthly",
      "title": "區里月人口",
      "domain": "population",
      "input": "population_village_monthly.csv",
      "output": "population_village_monthly.json",
      "required": true,
      "cadence": "monthly",
      "source": "嘉義市戶政服務網",
      "pages": ["/population"],
      "fields": ["year", "month", "district", "village", "households", "male", "female", "population"]
    },
    {
      "id": "county_population_comparison",
      "title": "跨縣市人口比較",
      "domain": "population",
      "input": "county_population_comparison.csv",
      "output": "county_population_comparison.json",
      "required": true,
      "cadence": "annual",
      "source": "內政部戶政司",
      "pages": ["/population/comparison"],
      "fields": ["rank", "county", "year", "population", "area_km2", "density"]
    },
    {
      "id": "budget_revenue_by_source",
      "title": "歲入來源別",
      "domain": "budget",
      "input": "budget_revenue_by_source.csv",
      "output": "budget_revenue_by_source.json",
      "required": true,
      "cadence": "annual",
      "source": "Open Chiayi",
      "pages": ["/", "/budget", "/narratives"],
      "fields": ["fiscal_year", "source_category", "amount"],
      "amountField": "amount"
    },
    {
      "id": "budget_expenditure_by_function",
      "title": "歲出政事別",
      "domain": "budget",
      "input": "budget_expenditure_by_function.csv",
      "output": "budget_expenditure_by_function.json",
      "required": true,
      "cadence": "annual",
      "source": "Open Chiayi",
      "pages": ["/", "/budget", "/narratives"],
      "fields": ["fiscal_year", "level", "parent_code", "code", "function_category", "recurring", "capital", "amount"],
      "amountField": "amount",
      "notes": "level 1 為合計層，level 2 為明細層；跨層加總會重複計算。"
    },
    {
      "id": "budget_expenditure_by_agency",
      "title": "歲出機關別",
      "domain": "budget",
      "input": "budget_expenditure_by_agency.csv",
      "output": "budget_expenditure_by_agency.json",
      "required": true,
      "cadence": "annual",
      "source": "Open Chiayi",
      "pages": ["/budget"],
      "fields": ["fiscal_year", "agency_name", "amount"],
      "amountField": "amount"
    },
    {
      "id": "budget_by_policy_domain",
      "title": "政策領域彙總",
      "domain": "budget",
      "input": "budget_by_policy_domain.csv",
      "output": "budget_by_policy_domain.json",
      "required": true,
      "cadence": "annual",
      "source": "政策分類器",
      "pages": ["/budget/policy", "/budget"],
      "fields": ["policy_domain", "policy_domain_en", "domain_order", "recurring", "capital", "amount", "high_confidence", "medium_confidence", "low_confidence", "item_count", "percentage", "confidence"],
      "amountField": "amount"
    },
    {
      "id": "budget_expenditure_classified",
      "title": "政事別政策分類明細",
      "domain": "budget",
      "input": "budget_expenditure_classified.csv",
      "output": "budget_expenditure_classified.json",
      "required": true,
      "cadence": "annual",
      "source": "政策分類器",
      "pages": ["/budget/policy"],
      "fields": ["fiscal_year", "level", "parent_code", "code", "function_category", "recurring", "capital", "amount", "policy_domain", "policy_domain_en", "domain_order", "confidence"],
      "amountField": "amount"
    },
    {
      "id": "budget_agency_classified",
      "title": "機關政策分類明細",
      "domain": "budget",
      "input": "budget_agency_classified.csv",
      "output": "budget_agency_classified.json",
      "required": true,
      "cadence": "annual",
      "source": "政策分類器",
      "pages": ["/budget/policy"],
      "fields": ["fiscal_year", "agency_name", "amount", "policy_domain", "policy_domain_en", "agency_confidence", "reason"],
      "amountField": "amount"
    },
    {
      "id": "budget_agency_by_domain",
      "title": "機關政策領域彙總",
      "domain": "budget",
      "input": "budget_agency_by_domain.csv",
      "output": "budget_agency_by_domain.json",
      "required": true,
      "cadence": "annual",
      "source": "政策分類器",
      "pages": ["/budget/policy"],
      "fields": ["policy_domain", "policy_domain_en", "amount", "agency_count", "high", "medium", "low", "none", "percentage"],
      "amountField": "amount"
    },
    {
      "id": "fund_operating",
      "title": "作業基金",
      "domain": "fund",
      "input": "fund_operating.csv",
      "output": "fund_operating.json",
      "required": true,
      "cadence": "annual",
      "source": "嘉義市政府主計處",
      "pages": ["/budget/funds"],
      "fields": ["fund_type", "item", "fund_name", "amount"],
      "amountField": "amount"
    },
    {
      "id": "fund_business",
      "title": "營業基金",
      "domain": "fund",
      "input": "fund_business.csv",
      "output": "fund_business.json",
      "required": true,
      "cadence": "annual",
      "source": "嘉義市政府主計處",
      "pages": ["/budget/funds"],
      "fields": ["fund_type", "item", "fund_name", "amount"],
      "amountField": "amount"
    },
    {
      "id": "fund_affairs",
      "title": "政事型基金",
      "domain": "fund",
      "input": "fund_affairs.csv",
      "output": "fund_affairs.json",
      "required": true,
      "cadence": "annual",
      "source": "嘉義市政府主計處",
      "pages": ["/budget/funds"],
      "fields": ["fund_type", "fund_name", "item", "amount", "category"],
      "amountField": "amount"
    },
    {
      "id": "cw_happy_city_rankings",
      "title": "天下永續幸福城市排名",
      "domain": "competitiveness",
      "input": "cw_happy_city_rankings.csv",
      "output": "cw_happy_city_rankings.json",
      "required": true,
      "cadence": "annual",
      "source": "天下雜誌",
      "pages": ["/competitiveness"],
      "fields": ["year", "group", "rank", "county", "total_score", "source"]
    },
    {
      "id": "cw_happy_city_dimensions",
      "title": "天下永續幸福城市面向",
      "domain": "competitiveness",
      "input": "cw_happy_city_dimensions.csv",
      "output": "cw_happy_city_dimensions.json",
      "required": true,
      "cadence": "annual",
      "source": "天下雜誌",
      "pages": ["/competitiveness"],
      "fields": ["year", "dimension", "county", "score", "rank_in_non_six", "note"]
    },
    {
      "id": "gvm_mayor_satisfaction",
      "title": "遠見縣市長施政滿意度",
      "domain": "competitiveness",
      "input": "gvm_mayor_satisfaction.csv",
      "output": "gvm_mayor_satisfaction.json",
      "required": true,
      "cadence": "annual",
      "source": "遠見雜誌",
      "pages": ["/competitiveness"],
      "fields": ["year", "county", "mayor", "overall_satisfaction", "star_rating", "avg_dimension_score", "rank_national", "note", "source"]
    }
  ]
}
